{% extends 'base.html.twig' %}

{% block title %}DRAMATIQUE{% endblock %}

{% block body %}
    <h1>Products</h1>

    <div class="table-container">
    <table class="table">
        <tbody>
            {% set isRentalOnly = product.collectionType is defined and product.collectionType and product.collectionType|lower == 'mascots' %}
            <tr>
                <th>Image</th>
                <td>
                    {% if product.image %}
                        <img src="{{ product.image }}" alt="{{ product.name }}" style="max-width: 300px; max-height: 300px; border-radius: 8px; border: 2px solid #e0e0e0; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);">
                    {% else %}
                        <span style="color: #999; font-style: italic;">No image available</span>
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ product.name }}</td>
            </tr>
            <tr>
                <th>Price</th>
                <td>{{ product.price }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ product.description }}</td>
            </tr>
            <tr>
                <th>Size</th>
                <td>
                    {% if isRentalOnly %}
                        <div style="padding:12px 14px;border:1px solid #eddccf;border-radius:8px;background:#fff8f1;color:#7b5a37;">
                            Mascot items are available for rental only.
                        </div>
                    {% elseif product.collectionType is defined and product.collectionType and product.collectionType|lower matches '/inflatable/' %}
                        <form method="post" action="{{ path('app_cart_add', {'id': product.id}) }}" style="display:flex;gap:12px;align-items:center;">
                            <input type="hidden" name="size" value="Standard" />
                            <button type="submit" class="btn btn-primary" style="padding:8px 12px;border-radius:8px;">Add to cart</button>
                        </form>
                    {% else %}
                        <form method="post" action="{{ path('app_cart_add', {'id': product.id}) }}" style="display:flex;gap:12px;align-items:center;">
                            <select name="size" style="padding:8px;border:1px solid #eae7e3;border-radius:8px;">
                                <option value="Standard">Standard</option>
                                <option value="Small">Small</option>
                                <option value="Medium">Medium</option>
                                <option value="Large">Large</option>
                            </select>
                            <button type="submit" class="btn btn-primary" style="padding:8px 12px;border-radius:8px;">Add to cart</button>
                        </form>
                    {% endif %}
                </td>
            </tr>
            {# Collection removed from product details as requested #}
        </tbody>
    </table>
    </div>

    <a href="{{ path('app_products_index') }}" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to list</a>

    {% set isOwner = product.getCreatedBy() and app.user and product.getCreatedBy().getId() == app.user.getId() %}
    {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') or isOwner %}
        <a href="{{ path('app_products_edit', {'id': product.id}) }}" class="btn btn-secondary"><i class="fas fa-edit"></i> Edit</a>

        {{ include('products/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
