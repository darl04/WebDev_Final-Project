{% extends 'base.html.twig' %}

{% block title %}Dramatique{% endblock %}

{% block body %}
<style>
    .content-wrapper {
        padding: 0 !important;
    }

    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(0, 0, 0, 0.1);
        z-index: 1000;
        padding: 1rem 0;
    }

    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .logo {
        font-size: 1.5rem;
        font-weight: 700;
        color: #8B5CF6;
        letter-spacing: -0.02em;
    }

    .nav-links {
        display: flex;
        list-style: none;
        gap: 1.75rem;
    }

    .nav-links a {
        text-decoration: none;
        color: #374151;
        font-weight: 500;
        transition: color 0.2s;
    }

    .nav-links a:hover {
        color: #8B5CF6;
    }

    .nav-links .nav-cta {
        background: #8B5CF6;
        color: #ffffff;
        padding: 0.6rem 1rem;
        border-radius: 9999px;
    }

    .nav-links .nav-cta:hover {
        background: #7C3AED;
        color: #ffffff;
    }

    .nav-toggle {
        display: none;
        width: 44px;
        height: 44px;
        border: 1px solid #d1d5db;
        background: #ffffff;
        border-radius: 0.7rem;
        cursor: pointer;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 5px;
        padding: 0;
    }

    .nav-toggle span {
        width: 18px;
        height: 2px;
        background: #374151;
        border-radius: 9999px;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .nav-toggle.is-open span:nth-child(1) {
        transform: translateY(7px) rotate(45deg);
    }

    .nav-toggle.is-open span:nth-child(2) {
        opacity: 0;
    }

    .nav-toggle.is-open span:nth-child(3) {
        transform: translateY(-7px) rotate(-45deg);
    }

    .contact-hero {
        padding: 100px 2rem 60px;
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.85) 0%, rgba(118, 75, 162, 0.85) 100%);
        color: white;
        text-align: center;
        min-height: 50vh;
        display: flex;
        align-items: center;
    }

    .contact-hero h1 {
        font-family: 'Poppins', sans-serif;
        font-size: clamp(2rem, 4vw, 3.5rem);
        margin-bottom: 1rem;
        line-height: 1.05;
    }

    .contact-hero p {
        font-family: 'Poppins', sans-serif;
        color: rgba(255, 255, 255, 0.88);
        font-size: 1.15rem;
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.75;
    }

    .section-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 4rem 2rem;
    }

    .contact-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .contact-card,
    .contact-form-card {
        background: white;
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
    }

    .contact-card h3,
    .contact-form-card h3 {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: #111827;
    }

    .contact-card h3 {
        text-align: center;
    }

    .contact-card p,
    .contact-card a,
    .contact-form-card p {
        color: #4B5563;
        line-height: 1.8;
        margin-bottom: 1rem;
    }

    .contact-card a {
        color: #8B5CF6;
        text-decoration: none;
        font-weight: 600;
    }

    .contact-card a:hover {
        text-decoration: underline;
    }

    .contact-item {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .contact-badge {
        width: 18px;
        height: 18px;
        background: #8B5CF6;
        border-radius: 50%;
        flex-shrink: 0;
        margin-top: 0.35rem;
    }

    .contact-form {
        display: grid;
        gap: 1rem;
    }

    .form-row {
        display: grid;
        gap: 0.5rem;
    }

    .form-row label {
        font-weight: 600;
        color: #111827;
        font-size: 0.95rem;
    }

    .form-row input,
    .form-row textarea {
        width: 100%;
        border: 1px solid #D1D5DB;
        border-radius: 0.75rem;
        padding: 0.95rem 1rem;
        font-size: 0.95rem;
        color: #111827;
        background: #F9FAFB;
    }

    .form-row textarea {
        min-height: 160px;
        resize: vertical;
    }

    .form-actions {
        display: flex;
        justify-content: flex-start;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.85rem 1.75rem;
        border-radius: 0.75rem;
        text-decoration: none;
        font-weight: 700;
        font-size: 1rem;
        font-family: 'Poppins', sans-serif;
        transition: transform 0.2s, box-shadow 0.2s, background-color 0.2s;
        border: none;
        cursor: pointer;
        min-width: 140px;
    }

    .btn-primary {
        background: #8B5CF6;
        color: white;
        box-shadow: 0 16px 40px rgba(139, 92, 246, 0.22);
    }

    .btn-primary:hover {
        background: #7C3AED;
        transform: translateY(-2px);
    }

    .footer {
        background: #1F2937;
        color: white;
        padding: 3rem 0 1rem;
    }

    .footer-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 2rem;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .footer-section h4 {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: white;
    }

    .footer-section ul {
        list-style: none;
    }

    .footer-section ul li {
        margin-bottom: 0.5rem;
    }

    .footer-section a {
        color: #9CA3AF;
        text-decoration: none;
        transition: color 0.2s;
    }

    .footer-section a:hover {
        color: white;
    }

    .social-links {
        display: flex;
        gap: 1rem;
    }

    .footer-bottom {
        border-top: 1px solid #374151;
        padding-top: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .simple-footer {
        background: #111827;
        width: 100%;
        margin-bottom: -32px;
    }

    .footer-bottom {
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.25rem 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .footer-bottom p {
        margin: 0;
        color: #9CA3AF;
        font-size: 0.95rem;
    }

    .footer-links {
        display: flex;
        gap: 1.5rem;
    }

    .footer-links a {
        color: #8B5CF6;
        text-decoration: none;
        font-size: 0.95rem;
    }

    .footer-links a:hover {
        color: #A78BFA;
    }

    @media (max-width: 1024px) {
        .nav-container {
            padding: 0 1.25rem;
        }

        .nav-links {
            gap: 1.25rem;
        }
    }

    @media (max-width: 768px) {
        .navbar {
            padding: 0.75rem 0;
        }

        .nav-container {
            padding: 0 0.9rem;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.6rem;
        }

        .logo {
            font-size: 1.35rem;
        }

        .nav-toggle {
            display: inline-flex;
        }

        .nav-links {
            display: none;
            width: 100%;
            flex-direction: column;
            gap: 0.25rem;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 0.9rem;
            padding: 0.35rem;
            box-shadow: 0 10px 26px rgba(15, 23, 42, 0.08);
        }

        .nav-links.is-open {
            display: flex;
        }

        .nav-links a {
            display: block;
            padding: 0.7rem 0.8rem;
            border-radius: 0.6rem;
        }

        .nav-links a:hover {
            background: #f5f3ff;
        }

        .nav-links .nav-cta {
            display: inline-flex;
            padding: 0.5rem 0.95rem;
            margin: 0.25rem 0.4rem 0.2rem;
        }

        .contact-hero {
            padding: 128px 1rem 48px;
            min-height: 42vh;
        }

        .contact-hero h1 {
            font-size: clamp(1.9rem, 8vw, 2.55rem);
        }

        .contact-hero p {
            font-size: 1rem;
        }

        .section-container {
            padding: 2.5rem 1rem;
        }

        .contact-grid {
            grid-template-columns: 1fr;
            gap: 1.25rem;
        }

        .contact-card,
        .contact-form-card {
            padding: 1.4rem;
        }

        .btn {
            width: 100%;
            max-width: 320px;
            min-width: 0;
        }

        .footer-container {
            grid-template-columns: 1fr;
            padding: 0 1rem;
            text-align: left;
        }

        .footer-bottom {
            flex-direction: column;
            align-items: flex-start;
            text-align: left;
            padding: 1rem;
        }

        .footer-links {
            gap: 1rem;
            flex-wrap: wrap;
        }
    }

    @media (max-width: 480px) {
        .nav-container {
            padding: 0 0.75rem;
        }

        .contact-hero {
            padding: 122px 0.75rem 42px;
        }

        .contact-hero h1 {
            font-size: clamp(1.7rem, 10vw, 2.15rem);
        }

        .section-container,
        .footer-container,
        .footer-bottom {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }
    }
</style>

<div class="landing-page">
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">DRAMATIQUE</div>
            <button class="nav-toggle" type="button" aria-label="Toggle navigation" aria-controls="contact-nav" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <ul id="contact-nav" class="nav-links">
                <li><a href="{{ path('app_home') }}">Home</a></li>
                <li><a href="{{ path('app_collection') }}">Collections</a></li>
                <li><a href="{{ path('app_about') }}">About Us</a></li>
                <li><a href="{{ path('app_contact') }}">Contact Us</a></li>
                <li><a href="{{ path('app_login') }}" class="nav-cta">Get Started</a></li>
            </ul>
        </div>
    </nav>

    <section class="contact-hero">
        <div class="hero-container">
            <h1>Contact Dramatique</h1>
            <p>We’re here to help with costume rentals, wardrobe planning, and production support. Reach out and our team will get back to you quickly.</p>
        </div>
    </section>

    <section class="section-container">
        <div class="contact-grid">
            <div class="contact-card">
                <h3>Contact information</h3>
                <div class="contact-item">
                    <span class="contact-badge"></span>
                    <p>2nd Floor, Magsaysay Building<br>Dumaguete City, Philippines</p>
                </div>
                <div class="contact-item">
                    <span class="contact-badge"></span>
                    <p>0912 345 6789</p>
                </div>
                <div class="contact-item">
                    <span class="contact-badge"></span>
                    <p>dramatique@gmail.com</p>
                </div>
                <p>Whether you are booking a rehearsal wardrobe, planning a stage production, or need help selecting costumes, our team is ready to support your next creative project.</p>
            </div>

            <div class="contact-form-card">
                <h3>Send us a message</h3>
                <p>Use the form below and we’ll be in touch within one business day.</p>
                <form class="contact-form">
                    <div class="form-row">
                        <label for="name">Name</label>
                        <input id="name" type="text" placeholder="Your full name">
                    </div>
                    <div class="form-row">
                        <label for="email">Email</label>
                        <input id="email" type="email" placeholder="you@example.com">
                    </div>
                    <div class="form-row">
                        <label for="message">Message</label>
                        <textarea id="message" placeholder="Write your message here"></textarea>
                    </div>
                    <div class="form-actions">
                        <button class="btn btn-primary" type="button">Send Message</button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    <footer class="simple-footer">
        <div class="footer-bottom">
            <p>© 2026 Dramatique. All rights reserved.</p>
            <div class="footer-links">
                <a href="#privacy">Privacy Policy</a>
                <a href="#terms">Terms of Service</a>
            </div>
        </div>
    </footer>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const toggleButton = document.querySelector('.nav-toggle');
    const navLinks = document.querySelector('#contact-nav');

    if (!toggleButton || !navLinks) {
        return;
    }

    toggleButton.addEventListener('click', function () {
        const isOpen = navLinks.classList.toggle('is-open');
        toggleButton.classList.toggle('is-open', isOpen);
        toggleButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    });

    navLinks.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', function () {
            if (window.innerWidth <= 768) {
                navLinks.classList.remove('is-open');
                toggleButton.classList.remove('is-open');
                toggleButton.setAttribute('aria-expanded', 'false');
            }
        });
    });

    document.addEventListener('click', function (event) {
        if (window.innerWidth > 768) {
            return;
        }

        const clickedInsideMenu = navLinks.contains(event.target) || toggleButton.contains(event.target);
        if (!clickedInsideMenu) {
            navLinks.classList.remove('is-open');
            toggleButton.classList.remove('is-open');
            toggleButton.setAttribute('aria-expanded', 'false');
        }
    });

    window.addEventListener('resize', function () {
        if (window.innerWidth > 768) {
            navLinks.classList.remove('is-open');
            toggleButton.classList.remove('is-open');
            toggleButton.setAttribute('aria-expanded', 'false');
        }
    });
});
</script>
{% endblock %}
