{% extends 'base.html.twig' %}

{% block title %}Cart{% endblock %}

{% block page_title %}Shopping Cart{% endblock %}

{% block stylesheets %}
    .cart-page {
        max-width: 1180px;
        margin: 0 auto;
    }

    .cart-header {
        margin-bottom: 22px;
    }

    .cart-title {
        font-size: 34px;
        font-weight: 700;
        color: #2c2320;
        margin-bottom: 6px;
    }

    .cart-subtitle {
        color: #7f7168;
        font-size: 14px;
    }

    .cart-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 24px;
        align-items: start;
    }

    .cart-table-card,
    .cart-summary {
        background: #ffffff;
        border: 1px solid #e9e2dd;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(36, 20, 10, 0.05);
    }

    .cart-table-card {
        padding: 18px;
    }

    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }

    .cart-table thead th {
        background: var(--primary-color);
        color: #ffffff;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 14px;
    }

    .cart-table thead th:first-child {
        border-top-left-radius: 12px;
    }

    .cart-table thead th:last-child {
        border-top-right-radius: 12px;
    }

    .cart-table tbody td {
        border-bottom: 1px solid #f0ece8;
        padding: 16px 14px;
        vertical-align: middle;
    }

    .remove-link {
        color: #7d6f64;
        text-decoration: none;
        font-size: 18px;
        width: 20px;
        display: inline-flex;
        justify-content: center;
    }

    .product-cell {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .product-thumb {
        width: 62px;
        height: 62px;
        border-radius: 10px;
        object-fit: cover;
        border: 1px solid #efe7e2;
        background: #f7f4f2;
    }

    .product-thumb-placeholder {
        width: 62px;
        height: 62px;
        border-radius: 10px;
        border: 1px solid #efe7e2;
        background: #f7f4f2;
        color: #8f8279;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        text-align: center;
        padding: 4px;
    }

    .product-name {
        font-weight: 700;
        color: #241a14;
        margin-bottom: 3px;
    }

    .product-meta {
        font-size: 12px;
        color: #8f8279;
    }

    .qty-control {
        display: inline-flex;
        align-items: center;
        border: 1px solid #e7dfda;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }

    .qty-btn {
        width: 34px;
        height: 34px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #4a3a31;
        text-decoration: none;
        font-weight: 700;
        border-right: 1px solid #efe7e2;
    }

    .qty-btn.plus {
        border-right: none;
        border-left: 1px solid #efe7e2;
    }

    .qty-value {
        min-width: 40px;
        text-align: center;
        font-weight: 700;
        color: #2c2320;
        font-size: 14px;
    }

    .money {
        font-weight: 700;
        color: #2d221c;
    }

    .cart-actions {
        display: flex;
        gap: 12px;
        justify-content: space-between;
        align-items: center;
        padding: 18px 0 0;
    }

    .cart-summary {
        padding: 18px;
        position: sticky;
        top: 24px;
    }

    .summary-title {
        font-size: 20px;
        font-weight: 700;
        color: #2b211b;
        margin-bottom: 14px;
    }

    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 0;
        border-bottom: 1px solid #f1ece8;
        color: #6f6258;
        font-size: 14px;
    }

    .summary-row:last-of-type {
        border-bottom: none;
    }

    .summary-total {
        margin-top: 8px;
        padding-top: 12px;
        border-top: 2px solid #ece3dd;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 800;
        color: #2f241d;
    }

    .btn-checkout {
        margin-top: 16px;
        width: 100%;
        display: inline-flex;
        justify-content: center;
        padding: 12px 14px;
        border-radius: 8px;
        background: var(--primary-color);
        color: #ffffff;
        text-decoration: none;
        font-weight: 700;
        box-shadow: 0 6px 16px rgba(207,166,240,0.12);
    }

    .btn-checkout:hover {
        background: var(--primary-dark);
    }

    .trust-row {
        margin-top: 24px;
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
    }

    .trust-card {
        background: #fff;
        border: 1px solid #ece3dd;
        border-radius: 10px;
        padding: 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .trust-icon {
        width: 36px;
        height: 36px;
        border-radius: 999px;
        background: #fff4dd;
        color: #7a4c1d;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .trust-title {
        font-weight: 700;
        color: #2d241d;
        font-size: 14px;
    }

    .trust-desc {
        color: #8d8179;
        font-size: 12px;
    }

    .empty-cart {
        background: #fff;
        border: 1px solid #e9e2dd;
        border-radius: 12px;
        padding: 32px;
        text-align: center;
    }

    @media (max-width: 980px) {
        .cart-layout {
            grid-template-columns: 1fr;
        }

        .trust-row {
            grid-template-columns: 1fr;
        }
    }
{% endblock %}

{% block body %}
    <section class="cart-page">
        <div class="cart-header">
            <p class="cart-subtitle">Review your selected products before checkout.</p>
        </div>

        {% if items is empty %}
            <div class="empty-cart">
                <p style="margin-bottom:16px;color:#7a6f67;">Your cart is empty.</p>
                <a href="{{ path('app_products_index') }}" class="btn btn-primary">Continue shopping</a>
            </div>
        {% else %}
            <div class="cart-layout">
                <div>
                    <div class="cart-table-card">
                        <table class="cart-table">
                            <thead>
                                <tr>
                                    <th style="width:44px;"></th>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for item in items %}
                                <tr>
                                        <td>
                                            <a href="{{ path('app_cart_remove', {'id': item.product.id}) }}" class="remove-link" title="Remove">
                                                <i class="fas fa-times"></i>
                                            </a>
                                        </td>
                                        <td>
                                            <div class="product-cell">
                                                {% if item.product.image %}
                                                    <img src="{{ item.product.image }}" alt="{{ item.product.name }}" class="product-thumb">
                                                {% else %}
                                                    <div class="product-thumb-placeholder">No image</div>
                                                {% endif %}
                                                <div>
                                                    <div class="product-name">{{ item.product.name }}</div>
                                                    <div class="product-meta">
                                                        {% set sizeLabel = item.size is defined and item.size ? item.size : 'Standard' %}
                                                        Size: {{ sizeLabel }}
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="money">₱{{ item.product.price|number_format(2, '.', ',') }}</td>
                                        <td>
                                            <div class="qty-control">
                                                <a class="qty-btn" href="{{ path('app_cart_update', {'id': item.product.id, 'action': 'minus'}) }}">-</a>
                                                <span class="qty-value">{{ item.quantity }}</span>
                                                <a class="qty-btn plus" href="{{ path('app_cart_update', {'id': item.product.id, 'action': 'plus'}) }}">+</a>
                                            </div>
                                        </td>
                                        <td class="money">₱{{ item.subtotal|number_format(2, '.', ',') }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>

                    <div class="cart-actions">
                        <a href="{{ path('app_products_index') }}" class="btn btn-secondary">Continue shopping</a>
                        <a href="{{ path('app_cart_clear') }}" class="btn btn-danger">Clear shopping cart</a>
                    </div>
                </div>

                <aside class="cart-summary">
                    <h2 class="summary-title">Order Summary</h2>
                    <div class="summary-row">
                        <span>Items</span>
                        <span>{{ count }}</span>
                    </div>
                    <div class="summary-row">
                        <span>Sub Total</span>
                        <span>₱{{ total|number_format(2, '.', ',') }}</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span>₱{{ shipping|default(0)|number_format(2, '.', ',') }}</span>
                    </div>
                    <div class="summary-total">
                        <span>Total</span>
                        <span>₱{{ (total + (shipping|default(0)))|number_format(2, '.', ',') }}</span>
                    </div>
                    <a href="{{ path('app_orders_new') }}" class="btn-checkout">Proceed to checkout</a>
                </aside>
            </div>
        {% endif %}
    </section>
{% endblock %}
