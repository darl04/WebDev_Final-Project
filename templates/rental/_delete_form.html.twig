<form method="post" action="{{ path('app_rental_delete', {'id': rental.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" class="delete-form" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ rental.id) }}">
    <button class="btn btn-danger"><i class="fas fa-trash"></i> Delete</button>
</form>

