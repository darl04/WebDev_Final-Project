{% extends 'base.html.twig' %}

{% block title %}DRAMATIQUE{% endblock %}

{% block stylesheets %}
    <style>
        .status-badge {
            display: inline-block;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-badge-pending {
            background: rgba(255, 152, 0, 0.1);
            color: #ff9800;
            border: 1px solid rgba(255, 152, 0, 0.3);
        }

        .status-badge-processing {
            background: rgba(33, 150, 243, 0.1);
            color: #2196F3;
            border: 1px solid rgba(33, 150, 243, 0.3);
        }

        .status-badge-shipped {
            background: rgba(156, 39, 176, 0.1);
            color: #9c27b0;
            border: 1px solid rgba(156, 39, 176, 0.3);
        }

        .status-badge-delivered {
            background: rgba(76, 175, 80, 0.1);
            color: #4CAF50;
            border: 1px solid rgba(76, 175, 80, 0.3);
        }

        .status-badge-cancelled {
            background: rgba(244, 67, 54, 0.1);
            color: #f44336;
            border: 1px solid rgba(244, 67, 54, 0.3);
        }

        .product-image {
            width: 120px;
            height: 120px;
            object-fit: cover;
            border-radius: 12px;
            border: 2px solid var(--border-color);
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            margin-right: 16px;
        }

        .product-item {
            display: flex;
            align-items: center;
            margin-bottom: 16px;
        }

        .product-item:last-child {
            margin-bottom: 0;
        }

        .product-info {
            flex: 1;
        }

        .product-name {
            font-weight: 600;
            font-size: 16px;
            color: var(--text-dark);
            margin-bottom: 4px;
        }

        .no-image {
            width: 120px;
            height: 120px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #f5f5f5;
            border-radius: 12px;
            border: 2px solid var(--border-color);
            color: #999;
            font-size: 14px;
            margin-right: 16px;
        }
    </style>
{% endblock %}

{% block body %}
    <h1>Orders</h1>

    <div class="table-container">
    <table class="table">
        <tbody>
            <tr>
                <th>Customer</th>
                <td>{{ order.customer ? order.customer.name : 'N/A' }}</td>
            </tr>
            <tr>
                <th>Products</th>
                <td>
                    {% if order.products|length > 0 %}
                        {% for product in order.products %}
                            <div class="product-item">
                                {% if product.image %}
                                    <img src="{{ product.image }}" alt="{{ product.name }}" class="product-image">
                                {% else %}
                                    <div class="no-image">No image</div>
                                {% endif %}
                                <div class="product-info">
                                    <div class="product-name">{{ product.name }}</div>
                                </div>
                            </div>
                        {% endfor %}
                    {% else %}
                        No products
                    {% endif %}
                </td>
            </tr>
            <tr>
                <th>Quantity</th>
                <td>{{ order.quantity }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>
                    {% set statusClass = order.status|lower|replace({' ': '-'}) %}
                    <span class="status-badge status-badge-{{ statusClass }}">{{ order.status }}</span>
                </td>
            </tr>
        </tbody>
    </table>
    </div>

    <a href="{{ path('app_orders_index') }}" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to list</a>

    {% set isOwner = order.getCreatedBy() and app.user and order.getCreatedBy().getId() == app.user.getId() %}
    {% set createdByAdmin = order.getCreatedBy() and 'ROLE_ADMIN' in order.getCreatedBy().getRoles() %}
    {% if is_granted('ROLE_ADMIN') or isOwner or (is_granted('ROLE_STAFF') and createdByAdmin) %}
        <a href="{{ path('app_orders_edit', {'id': order.id}) }}" class="btn btn-secondary"><i class="fas fa-edit"></i> Edit</a>

        {{ include('orders/_delete_form.html.twig') }}
    {% endif %}
{% endblock %}
